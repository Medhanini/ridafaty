# Copy this file to .env and fill in your values.
# Variables prefixed with NUXT_PUBLIC_ are exposed to the browser.
# All others are server-only.

# ---------------------------------------------------------------------------
# Server-only secrets
# ---------------------------------------------------------------------------
NUXT_API_SECRET=your-super-secret-key

# ---------------------------------------------------------------------------
# Public runtime config (visible in the browser bundle)
# ---------------------------------------------------------------------------
NUXT_PUBLIC_API_BASE=https://api.example.com

# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX) — only loaded in production
NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX

# Canonical site URL used by the sitemap generator
NUXT_PUBLIC_SITE_URL=https://idafaty.com
