# Copy to .env and fill in your values.
# This file is committed – never put real secrets here.

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=ridafaty
MYSQL_USER=ridafaty
MYSQL_PASSWORD=secret

# ── Backend (Node/Express) ────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=mysql://ridafaty:secret@mysql:3306/ridafaty
JWT_SECRET=ridafaty-dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=debug

# ── Frontend (Nuxt) ───────────────────────────────────────────────────────────
NUXT_API_SECRET=your-super-secret-key
NUXT_PUBLIC_API_BASE=http://localhost:3001/api
