# =============================================================================
# Production environment variables – idafaty.com
#
# Copy to .env.prod on the VPS and fill in real values.
# NEVER commit .env.prod to git.
# =============================================================================

# ── GitHub ────────────────────────────────────────────────────────────────────
# Your GitHub username / org (used to build GHCR image paths)
GITHUB_REPO_OWNER=YOUR_GITHUB_USERNAME

# ── Database ─────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=ridafaty
MYSQL_USER=ridafaty
MYSQL_PASSWORD=change_me_db_password

# ── Backend ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars

# ── Frontend / Nuxt ───────────────────────────────────────────────────────────
NUXT_API_SECRET=change_me_nuxt_api_secret
# These are set directly in docker-compose.prod.yml — no need to repeat here
# NUXT_PUBLIC_API_BASE=https://idafaty.com/api
# NUXT_API_BASE_INTERNAL=http://backend:3001/api
