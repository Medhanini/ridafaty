# Copy to .env and fill in your values.

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# MySQL connection string – use service name "mysql" inside Docker
DATABASE_URL="mysql://ridafaty:secret@mysql:3306/ridafaty"

# JWT – use a long random string in production (32+ chars)
JWT_SECRET=change-me-to-a-very-long-random-secret-string
JWT_EXPIRES_IN=7d

# bcrypt cost factor (10–14 recommended; higher = slower but safer)
BCRYPT_ROUNDS=12

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=debug
